="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex"><w:body><w:p><w:pPr><w:spacing w:after="100"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="000000"/><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr><w:t xml:space="preserve">FLUXEL - KOMPLETNA REVIZIJA COPY-JA</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:color w:val="999999"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">Instrukcije za Claude Code / Codex</w:t></w:r></w:p><w:p><w:pPr><w:pBdr><w:bottom w:val="single" w:color="00BCD4" w:sz="2"/></w:pBdr><w:spacing w:after="400"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="FF4444"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">Sve izmene su finalne - implementiraj tačno kako piše</w:t></w:r></w:p><w:p><w:pPr><w:shd w:fill="FFF3CD" w:val="clear"/><w:spacing w:after="200" w:before="200"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">NAPOMENA ZA AI: </w:t></w:r><w:r><w:rPr><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">Ovaj dokument sadrži kompletan revidirani copy za fluxelagency.vercel.app sajt. Zameni svaki navedeni deo tačno kako je napisano. Koristi latinične kvačice (</w:t></w:r><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">✓</w:t></w:r><w:r><w:rPr><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">), obične crtice (-) umesto dugačkih crtica, i veliko slovo V za persiranje i koristi srpska slova sa kvačicama (čćžšđ).</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">1. HERO SEKCIJA</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">OBRISATI: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;10+ zadovoljnih klijenata&quot; badge i &quot;Dostupni 7 dana u nedelji&quot; ispod njega.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">Headline (ostaje isti):</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">Koliko klijenata ste izgubili danas jer </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="00BCD4"/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">nisu mogli da zakažu online?</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">Subheadline (IZMENITI):</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI TEKST: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Pravimo sistem za online zakazivanje i profesionalni web sajt koji radi za vas 24/7 - čak i dok spavate.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI TEKST: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Pravimo sisteme za zakazivanje koji rade umesto Vas - 24/7. Bez Viber haosa, bez propuštenih termina, bez ručnog podsećanja.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">CTA dugmad (IZMENITI):</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Primarni CTA: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Zakažite besplatan razgovor (15 min)&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Sekundarni CTA: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Pogledaj kako funkcioniše&quot; </w:t></w:r><w:r><w:rPr><w:color w:val="999999"/></w:rPr><w:t xml:space="preserve">(ostaje isto)</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">Social proof zamena:</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:t xml:space="preserve">Umesto zvezdica i &quot;10+ zadovoljnih klijenata&quot;, stavi jednu rečenicu: </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">&quot;Specijalizovani isključivo za servisne biznise u Srbiji&quot;</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">2. PROBLEM SEKCIJA (&quot;Prepoznajete li ovo?&quot;)</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">Headline (IZMENITI):</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Svaki dan bez sistema za zakazivanje košta vas novac&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI: </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">&quot;Svaki dan bez sistema za zakazivanje </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="FF4444"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">košta Vas novac</w:t></w:r><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Napomena: </w:t></w:r><w:r><w:t xml:space="preserve">Samo promena malih/velikih slova - &quot;vas&quot; postaje &quot;Vas&quot;.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">Subheadline (IZMENITI):</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Razgovarali smo sa desetinama vlasnika malih biznisa u Srbiji. Evo šta čujemo iznova i iznova.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Ovo su problemi koje čujemo od vlasnika servisnih biznisa svake nedelje.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">Problem kartice (IZMENITI TEKST):</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50" w:before="150"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Kartica 1 - naslov: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Klijenti zovu dok ste zauzeti - i odu kod konkurencije&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI opis: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Svaki propušten poziv je propušten prihod. Dok ste u radu sa jednim klijentom, drugi odlazi kod nekoga ko ima online zakazivanje.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="150"/></w:pPr><w:r><w:rPr><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI opis: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Dok radite sa jednim klijentom, drugi zove, ne dobija odgovor, i zakazuje kod konkurencije koja ima online zakazivanje. Svaki propušten poziv = propušten novac.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50" w:before="150"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Kartica 2 - naslov: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Viber poruke se gomilaju, termini se gube u haosu&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI opis: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Zakazivanje kroz Viber je nepouzdano - poruke se brišu, termini se dupliraju, a vi stalno proveravate telefon.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="150"/></w:pPr><w:r><w:rPr><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI opis: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Poruke se brišu, termini se dupliraju, klijenti se ljute kad dođe do zabune. Vi provlačite telefon umesto da radite svoj posao.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50" w:before="150"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Kartica 3 - naslov (IZMENITI): </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Klijenti ne dolaze jer nema automatskih podsećanja&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI opis: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Bez automatskog SMS ili email podsećanja, svaki deseti termin je &apos;no-show&apos; - izgubljen prihod koji niko nije otkazao.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="150"/></w:pPr><w:r><w:rPr><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI opis: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Bez automatskog podsećanja, klijenti jednostavno zaborave. Svaki no-show je termin koji ste mogli popuniti nekim drugim - ali niste znali na vreme.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50" w:before="150"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Kartica 4 - naslov: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Nemate sajt ili imate sajt koji ne radi ništa za Vas&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI opis: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Ako vas ne mogu pronaći na Googlu ili ne mogu odmah zakazati sa vašeg sajta, klijent odlazi dalje za 30 sekundi.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="150"/></w:pPr><w:r><w:rPr><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI opis: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Ako Vas ne mogu pronaći na Googlu ili ne mogu odmah zakazati sa Vašeg sajta - klijent odlazi dalje za 30 sekundi. Vaš sajt treba da radi za Vas, ne samo da postoji.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50" w:before="150"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Kartica 5 - naslov (IZMENITI): </w:t></w:r><w:r><w:rPr><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Trošite sate na administraciju umesto na rad koji volite&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI naslov: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Svako jutro počinjete sa administracijom umesto pravim poslom&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI opis: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Svako jutro prepisivanje termina, podsećanje klijenata, odgovaranje na iste poruke - to su sati ukradeni od vašeg stvarnog posla.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:rPr><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI opis: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Prepisivanje termina, podsećanje klijenata, odgovaranje na iste poruke - svaki dan izgubite 1-2 sata na posao koji može da radi sistem umesto Vas.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">3. CITAT BLOK</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">KOMPLETNO OBRISATI </w:t></w:r><w:r><w:t xml:space="preserve">stari self-quote: &quot;Znamo ovo jer smo to čuli od desetina vlasnika biznisa...&quot; - Fluxel</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">ZAMENITI SA: </w:t></w:r><w:r><w:t xml:space="preserve">Jednostavan tekst bez quote formata: </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">&quot;Ovi problemi su isti za svaki servisni biznis - frizere, kozmetičare, terapeute. Rešenje takođe.&quot;</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">4. REŠENJE SEKCIJA</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t xml:space="preserve">Headline (IZMENITI):</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="50"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="FF4444"/></w:rPr><w:t xml:space="preserve">STARI: </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">&quot;Sistem koji radi umesto vas - čak i kad spavate&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="28A745"/></w:rPr><w:t xml:space="preserve">NOVI: </w:t></w:r><w:r><w:t xml:space="preserve">&quot;Sistem koji radi umesto Vas - čak i kad spavate&quot;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Napomena: </w:t></w:r><